# Copy to `.env` and fill in. Never commit the real .env.

# Zoho data centre: in | com | eu | com.au | jp
ZOHO_DC=in

# --- OAuth (from https://api-console.zoho.in — Self Client) ---
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Long-lived refresh token (generated once from the grant code).
ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxx

# --- Creator app ---
# The login name that OWNS the Creator app (segment after /appbuilder/ in the URL).
CREATOR_ACCOUNT_OWNER=account_owner_name
CREATOR_APP_LINK_NAME=airatrex
CREATOR_FORM_LINK_NAME=Vendor_Quotations
CREATOR_SUBFORM_LINK_NAME=Quotation_Items
CREATOR_RFQ_FIELD=RFQ
CREATOR_VENDOR_FIELD=Vendor_Master
CREATOR_DEFAULT_STATUS=Pending Review
# Per-line Status on Quotation_Items subform only (parent Status field removed)
CREATOR_ITEM_STATUS_FIELD=Status
CREATOR_QUOTATION_VERSION_FIELD=Quotation_Version
CREATOR_AVAILABLE_QUANTITY_FIELD=Available_Quantity
CREATOR_ITEM_MASTER_REPORT=Items_Report
CREATOR_ITEM_MASTER_NAME_FIELD=Name
CREATOR_RFQ_PRODUCTS_SUBFORM=RFQ_Products
CREATOR_RFQ_REPORT=RFQ1
CREATOR_RFQ_VENDOR_SELECTION=Vendor_Selection
CREATOR_VENDOR_EMAIL_FIELD=email
CREATOR_RFQ_FORM=RFQ
CREATOR_WORKSPACE=airatrex959

# Custom API — Vendor_Response_Status = Received
# Endpoint: https://www.zohoapis.in/creator/custom/airatrex959/Mark_Vendor_Quote_Received
#
# REQUIRED: In Creator → Microservices → Mark_Vendor_Quote_Received
#   Change Authentication from OAuth2 → Public Key (same as Send_Notification_to_vendor)
#   Copy public key → CREATOR_MARK_RECEIVED_PUBLIC_KEY below
CREATOR_MARK_RECEIVED_API=Mark_Vendor_Quote_Received
CREATOR_MARK_RECEIVED_PUBLIC_KEY=paste_public_key_from_creator_summary

# OAuth scope must include ZohoCreator.form.CREATE and ZohoCreator.report.UPDATE
# (or ZohoCreator.report.ALL) so quotations can be created and RFQ Vendor_Selection
# can be patched after submit.

# --- Server ---
PORT=8787
# Comma-separated list of allowed origins for CORS (your form's URL).
ALLOWED_ORIGINS=http://localhost:5173,https://aire-trex.vercel.app
