# Copy to `.env` and fill in. Never commit the real .env.

# Zoho data centre: in | com | eu | com.au | jp
ZOHO_DC=in

# --- OAuth (from https://api-console.zoho.in — Self Client) ---
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Long-lived refresh token (generated once from the grant code).
ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxx

# --- Creator app ---
# The login name that OWNS the Creator app (segment after /appbuilder/ in the URL).
CREATOR_ACCOUNT_OWNER=account_owner_name
CREATOR_APP_LINK_NAME=airatrex
CREATOR_FORM_LINK_NAME=Vendor_Quotations
CREATOR_SUBFORM_LINK_NAME=Quotation_Items
CREATOR_RFQ_FIELD=RFQ
CREATOR_DEFAULT_STATUS=Pending Review
CREATOR_ITEM_MASTER_REPORT=Items_Report

# --- Server ---
PORT=8787
# Comma-separated list of allowed origins for CORS (your form's URL).
ALLOWED_ORIGINS=http://localhost:5173,https://aire-trex.vercel.app
