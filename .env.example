# Local secrets — copy to .env and fill real values. DO NOT commit .env.

# Zoho data centre
ZOHO_DC=in

# --- OAuth (Self Client from https://api-console.zoho.in) ---
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
# Fill after exchanging your grant code.
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# --- Creator app ---
# The login name after /appbuilder/ in your Creator app URL.
CREATOR_ACCOUNT_OWNER=your_creator_account_owner
CREATOR_APP_LINK_NAME=airatrex
CREATOR_FORM_LINK_NAME=Vendor_Quotations
CREATOR_SUBFORM_LINK_NAME=Quotation_Items
CREATOR_DEFAULT_STATUS=Pending Review
# Quotation_Items: set when vendor edits the RFQ product name (Item_Master still filled)
# CREATOR_ACTUAL_PRODUCT_NAME_FIELD=Actual_Product_Name

# RFQ report + mark-received Custom API (Public Key)
CREATOR_WORKSPACE=your_creator_workspace
CREATOR_RFQ_REPORT=RFQ1
CREATOR_MARK_RECEIVED_API=Mark_Vendor_Quote_Received
CREATOR_MARK_RECEIVED_PUBLIC_KEY=your_mark_received_public_key

# RFQ Due_Date + vendor notification Custom APIs (Public Key auth)
CREATOR_RFQ_DUE_DATE_FIELD=Due_Date
CREATOR_QUOTATION_CONFIRM_API=Send_Quotation_Confirmation
CREATOR_QUOTATION_CONFIRM_PUBLIC_KEY=your_quotation_confirm_public_key
CREATOR_DUE_DATE_PASSED_API=Send_Due_Date_Passed_Notice
CREATOR_DUE_DATE_PASSED_PUBLIC_KEY=your_due_date_passed_public_key

# --- Server ---
PORT=8787
ALLOWED_ORIGINS=http://localhost:5173,https://aire-trex.vercel.app
